# InfraGuard Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically when InfraGuard reads its config.

# ── Dashboard API ─────────────────────────────────────────────────────
# Bearer token required for all /api/* endpoints.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INFRAGUARD_API_TOKEN=

# ── TLS Certificates ─────────────────────────────────────────────────
# Paths to your TLS cert and key. Referenced in config.yaml via
# ${INFRAGUARD_TLS_CERT} and ${INFRAGUARD_TLS_KEY}.
INFRAGUARD_TLS_CERT=/etc/letsencrypt/live/example.com/fullchain.pem
INFRAGUARD_TLS_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# ── Upstream Teamservers ──────────────────────────────────────────────
# Address of your C2 teamserver(s). Referenced in config.yaml via
# ${INFRAGUARD_CS_UPSTREAM} etc.
INFRAGUARD_CS_UPSTREAM=https://10.0.0.5:8443
INFRAGUARD_MYTHIC_UPSTREAM=https://10.0.0.6:443

# ── GeoIP ─────────────────────────────────────────────────────────────
# Path to MaxMind GeoLite2 database (optional).
INFRAGUARD_GEOIP_DB=

# ── Logging ───────────────────────────────────────────────────────────
INFRAGUARD_LOG_LEVEL=INFO
